{
  "name": "beam-web",
  "private": true,
  "type": "module",
  "scripts": {
    "export-schema": "cd ../beam-stream && cargo run --bin export_schema > schema.graphql",
    "codegen": "graphql-codegen --config codegen.ts",
    "codegen:full": "bun run export-schema && bun run codegen",
    "export-openapi": "cd ../beam-stream && cargo run --example export_openapi > ../beam-web/openapi.json",
    "codegen:openapi": "openapi-typescript ./openapi.json -o ./src/api.gen.ts",
    "codegen:openapi:full": "bun run export-openapi && bun run codegen:openapi",
    "dev": "vite",
    "build": "vite build && tsc",
    "serve": "vite preview",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "format": "biome format .",
    "lint": "biome lint .",
    "check": "biome check .",
    "lint:fix": "biome lint --write .",
    "format:fix": "biome format --write .",
    "check:fix": "biome check --write ."
  },
  "dependencies": {
    "@apollo/client": "^4.0.7",
    "@faker-js/faker": "^10.0.0",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.6",
    "@t3-oss/env-core": "^0.13.8",
    "@tailwindcss/vite": "^4.0.6",
    "@tanstack/match-sorter-utils": "^8.19.4",
    "@tanstack/react-devtools": "^0.7.0",
    "@tanstack/react-form": "^1.0.0",
    "@tanstack/react-query": "^5.66.5",
    "@tanstack/react-query-devtools": "^5.84.2",
    "@tanstack/react-router": "^1.132.0",
    "@tanstack/react-router-devtools": "^1.132.0",
    "@tanstack/react-table": "^8.21.2",
    "@tanstack/router-plugin": "^1.132.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "graphql": "^16.11.0",
    "lucide-react": "^0.546.0",
    "openapi-fetch": "^0.17.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "rxjs": "^7.8.2",
    "tailwind-merge": "^3.0.2",
    "tailwindcss": "^4.0.6",
    "tw-animate-css": "^1.3.6",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^6.0.1",
    "@graphql-codegen/typescript": "^5.0.2",
    "@graphql-codegen/typescript-operations": "^5.0.2",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.2.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.9.1",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.0.4",
    "@vitest/coverage-v8": "^4.0.18",
    "baseline-browser-mapping": "^2.9.19",
    "jsdom": "^27.0.0",
    "msw": "^2.12.10",
    "openapi-typescript": "^7.13.0",
    "typescript": "^5.7.2",
    "vite": "^7.1.7",
    "vitest": "^4.0.18",
    "web-vitals": "^5.1.0"
  }
}
